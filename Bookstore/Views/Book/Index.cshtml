@model Bookstore.Models.BookViewModel

@{
    ViewData["Title"] = "Books Dashboard";
}

<div class="max-w-6xl mx-auto space-y-8">

    <!-- Form Section -->
    <div class="bg-white shadow rounded-2xl p-6">
        <h2 class="text-2xl font-semibold text-gray-800 mb-4">
            Create New Book
        </h2>

        <form asp-controller="Book" asp-action="Store" method="post" class="grid grid-cols-1 md:grid-cols-2 gap-4">

            <!-- Name -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Title</label>
                <input name="Title" type="text" required
                       class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-gray-800 outline-none"/>
            </div>

            <!-- Email -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Author</label>
                <input name="Author" type="text" required
                       class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-gray-800 outline-none"/>
            </div>

            <!-- Submit -->
            <div class="md:col-span-2 text-right">
                <button type="submit"
                        class="bg-gray-900 text-white px-6 py-2 rounded-lg hover:bg-gray-700 transition">
                    Save Book
                </button>
            </div>

        </form>
    </div>

    <!-- Table Section -->
    <div class="bg-white shadow rounded-2xl p-6">
        <h2 class="text-2xl font-semibold text-gray-800 mb-4">
            Registered Books
        </h2>

        <div class="overflow-x-auto">
            <table class="min-w-full border border-gray-200 rounded-lg overflow-hidden">
                <thead class="bg-gray-900 text-white">
                <tr>
                    <th class="px-4 py-2 text-left text-sm">Title</th>
                    <th class="px-4 py-2 text-left text-sm">Author</th>
                    <th class="px-4 py-2 text-left text-sm">Actions</th>
                </tr>
                </thead>

                <tbody class="bg-white divide-y">
                @if (Model.BookList != null && Model.BookList.Any())
                {
                    foreach (var book in Model.BookList)
                    {
                        <tr class="hover:bg-gray-100 transition">
                            <td class="px-4 py-2">@book.Title</td>
                            <td class="px-4 py-2">@book.Author</td>
                            <td class="px-4 py-2 space-x-2">

                                <button 
                                    class="bg-green-500 text-white px-3 py-1 rounded hover:bg-green-600 text-sm"
                                    onclick="openDetailsModal(@book.Id, '@book.Title', '@book.Author')">
                                    Details
                                </button>

                                <button 
                                    class="bg-blue-500 text-white px-3 py-1 rounded hover:bg-blue-600 text-sm"
                                    onclick="openEditModal(@book.Id, '@book.Title', '@book.Author')">
                                    Edit
                                </button>

                                <form asp-controller="Book" asp-action="DeleteBook" asp-route-id="@book.Id" 
                                      method="post" class="inline">
                                    <button type="submit"
                                            class="bg-red-500 text-white px-3 py-1 rounded hover:bg-red-600 text-sm">
                                        Delete
                                    </button>
                                </form>

                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center px-4 py-4 text-gray-500">
                            No books registered yet.
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>

    </div>

</div>

<!-- Details Modal -->
<div id="detailsModal" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50">

    <div class="bg-white rounded-2xl shadow-lg w-full max-w-md p-6">
        <h2 class="text-xl font-semibold mb-4">Book Details</h2>

        <div class="space-y-2 text-gray-700">
            <p><strong>Id:</strong> <span id="detailsId"></span></p>
            <p><strong>Title:</strong> <span id="detailsTitle"></span></p>
            <p><strong>Author:</strong> <span id="detailsAuthor"></span></p>
        </div>

        <div class="mt-6 text-right">
            <button onclick="closeModal('detailsModal')"
                    class="bg-gray-800 text-white px-4 py-2 rounded hover:bg-gray-700">
                Close
            </button>
        </div>
    </div>

</div>

@* <!-- Edit Modal --> *@
<div id="editModal" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50">

    <div class="bg-white rounded-2xl shadow-lg w-full max-w-md p-6">
        <h2 class="text-xl font-semibold mb-4">Edit Book</h2>

        <form method="post" asp-controller="Book" asp-action="EditBook">

            <input type="hidden" id="editId" name="Id" />

            <div class="space-y-4">

                <div>
                    <label class="block text-sm mb-1">Title</label>
                    <input id="editTitle" name="Title" type="text"
                           class="w-full px-3 py-2 border rounded-lg"/>
                </div>

                <div>
                    <label class="block text-sm mb-1">Author</label>
                    <input id="editAuthor" name="Author" type="text"
                           class="w-full px-3 py-2 border rounded-lg"/>
                </div>

            </div>

            <div class="mt-6 flex justify-end space-x-2">
                <button type="button"
                        onclick="closeModal('editModal')"
                        class="bg-gray-400 text-white px-4 py-2 rounded">
                    Cancel
                </button>

                <button type="submit"
                        class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700">
                    Save Changes
                </button>
            </div>

        </form>
    </div>

</div>

@section Scripts {
    <script>
        function openDetailsModal(id, title, author) {
            document.getElementById('detailsId').innerText = id;
            document.getElementById('detailsTitle').innerText = title;
            document.getElementById('detailsAuthor').innerText = author;
    
            showModal('detailsModal');
        }
    
        function openEditModal(id, title, author) {
            document.getElementById('editId').value = id;
            document.getElementById('editTitle').value = title;
            document.getElementById('editAuthor').value = author;
    
            showModal('editModal');
        }
    
        function showModal(id) {
            const modal = document.getElementById(id);
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }
    
        function closeModal(id) {
            const modal = document.getElementById(id);
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }
        
        window.onclick = function(event) {
            ['detailsModal', 'editModal'].forEach(id => {
                const modal = document.getElementById(id);
                if (event.target === modal) {
                    closeModal(id);
                }
            });
        }
</script>
}