<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - Bookstore</title>

    <!-- Tailwind CDN -->
    <script src="https://cdn.tailwindcss.com"></script>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/Bookstore.styles.css" asp-append-version="true"/>
</head>

<body class="bg-gray-100">

<div class="flex h-screen">

    <!-- Sidebar -->
    <aside class="w-64 bg-gray-900 text-white flex flex-col">
        <div class="p-4 text-xl font-bold border-b border-gray-700">
            Bookstore
        </div>

        <nav class="flex-1 p-4 space-y-2">
            <a asp-controller="Book" asp-action="Index"
                class="block px-4 py-2 rounded-lg hover:bg-gray-700 transition">
                📚 Books
            </a>

            <a asp-controller="User" asp-action="Index"
                class="block px-4 py-2 rounded-lg hover:bg-gray-700 transition">
                👤 Users
            </a>

            <a asp-controller="Loan" asp-action="Index"
                class="block px-4 py-2 rounded-lg hover:bg-gray-700 transition">
                🔄 Loans
            </a>
        </nav>

        <div class="p-4 border-t border-gray-700 text-sm text-gray-400">
            &copy; 2026 Bookstore
        </div>
    </aside>

    <!-- Main Content -->
    <div class="flex-1 flex flex-col">

        <!-- Topbar (opcional) -->
        <header class="bg-white shadow px-6 py-4">
            <h1 class="text-lg font-semibold">
                @ViewData["Title"]
            </h1>
        </header>

        <!-- Page Content -->
        <main class="flex-1 p-6 overflow-y-auto">
            @RenderBody()
        </main>

    </div>

</div>

@await RenderSectionAsync("Scripts", required: false)

</body>
</html>