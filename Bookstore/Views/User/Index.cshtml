@model Bookstore.Models.UserViewModel

@{
    ViewData["Title"] = "Users Dashboard";
}

<div class="max-w-6xl mx-auto space-y-8">

    <!-- Form Section -->
    <div class="bg-white shadow rounded-2xl p-6">
        <h2 class="text-2xl font-semibold text-gray-800 mb-4">
            Create New User
        </h2>

        <form asp-controller="User" asp-action="Store" method="post" class="grid grid-cols-1 md:grid-cols-2 gap-4">

            <!-- Name -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Name</label>
                <input name="Name" type="text" required
                       class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-gray-800 outline-none"/>
            </div>

            <!-- Email -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                <input name="Email" type="email" required
                       class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-gray-800 outline-none"/>
            </div>

            <!-- C.C -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">C.C</label>
                <input name="Document" type="text" required
                       class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-gray-800 outline-none"/>
            </div>

            <!-- Age -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Age</label>
                <input name="Age" type="number" min="0" required
                       class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-gray-800 outline-none"/>
            </div>

            <!-- Submit -->
            <div class="md:col-span-2 text-right">
                <button type="submit"
                        class="bg-gray-900 text-white px-6 py-2 rounded-lg hover:bg-gray-700 transition">
                    Save User
                </button>
            </div>

        </form>
    </div>

    <!-- Table Section -->
    <div class="bg-white shadow rounded-2xl p-6">
        <h2 class="text-2xl font-semibold text-gray-800 mb-4">
            Registered Users
        </h2>

        <div class="overflow-x-auto">
            <table class="min-w-full border border-gray-200 rounded-lg overflow-hidden">
                <thead class="bg-gray-900 text-white">
                <tr>
                    <th class="px-4 py-2 text-left text-sm">Name</th>
                    <th class="px-4 py-2 text-left text-sm">Email</th>
                    <th class="px-4 py-2 text-left text-sm">C.C</th>
                    <th class="px-4 py-2 text-left text-sm">Age</th>
                    <th class="px-4 py-2 text-left text-sm">Actions</th>
                </tr>
                </thead>

                <tbody class="bg-white divide-y">
                @if (Model.UserList != null && Model.UserList.Any())
                {
                    foreach (var user in Model.UserList)
                    {
                        <tr class="hover:bg-gray-100 transition">
                            <td class="px-4 py-2">@user.Name</td>
                            <td class="px-4 py-2">@user.Email</td>
                            <td class="px-4 py-2">@user.Document</td>
                            <td class="px-4 py-2">@user.Age</td>
                            <td class="px-4 py-2 space-x-2">

                                <button 
                                    class="bg-green-500 text-white px-3 py-1 rounded hover:bg-green-600 text-sm"
                                    onclick="openDetailsModal(@user.Id, '@user.Name', '@user.Email', '@user.Document', @user.Age)">
                                    Details
                                </button>

                                <button 
                                    class="bg-blue-500 text-white px-3 py-1 rounded hover:bg-blue-600 text-sm"
                                    onclick="openEditModal(@user.Id, '@user.Name', '@user.Email', '@user.Document', @user.Age)">
                                    Edit
                                </button>

                                <form asp-controller="" asp-action="" asp-route-id="@user.Id" 
                                      method="post" class="inline">
                                    <button type="submit"
                                            class="bg-red-500 text-white px-3 py-1 rounded hover:bg-red-600 text-sm">
                                        Delete
                                    </button>
                                </form>

                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center px-4 py-4 text-gray-500">
                            No users registered yet.
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>

    </div>

</div>

<!-- Details Modal -->
<div id="detailsModal" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50">

    <div class="bg-white rounded-2xl shadow-lg w-full max-w-md p-6">
        <h2 class="text-xl font-semibold mb-4">User Details</h2>

        <div class="space-y-2 text-gray-700">
            <p><strong>Name:</strong> <span id="detailsName"></span></p>
            <p><strong>Email:</strong> <span id="detailsEmail"></span></p>
            <p><strong>User Document:</strong> <span id="detailsDocument"></span></p>
            <p><strong>Age:</strong> <span id="detailsAge"></span></p>
        </div>

        <div class="mt-6 text-right">
            <button onclick="closeModal('detailsModal')"
                    class="bg-gray-800 text-white px-4 py-2 rounded hover:bg-gray-700">
                Close
            </button>
        </div>
    </div>

</div>

<!-- Edit Modal -->
<div id="editModal" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50">

    <div class="bg-white rounded-2xl shadow-lg w-full max-w-md p-6">
        <h2 class="text-xl font-semibold mb-4">Edit User</h2>

        <form method="post" asp-controller="" asp-action="">

            <input type="hidden" id="editId" name="Id" />

            <div class="space-y-4">

                <div>
                    <label class="block text-sm mb-1">Name</label>
                    <input id="editName" name="Name" type="text"
                           class="w-full px-3 py-2 border rounded-lg"/>
                </div>

                <div>
                    <label class="block text-sm mb-1">Email</label>
                    <input id="editEmail" name="Email" type="email"
                           class="w-full px-3 py-2 border rounded-lg"/>
                </div>

                <div>
                    <label class="block text-sm mb-1">User Document</label>
                    <input id="editDocument" name="UserDocument" type="text"
                           class="w-full px-3 py-2 border rounded-lg"/>
                </div>

                <div>
                    <label class="block text-sm mb-1">Age</label>
                    <input id="editAge" name="Age" type="number"
                           class="w-full px-3 py-2 border rounded-lg"/>
                </div>

            </div>

            <div class="mt-6 flex justify-end space-x-2">
                <button type="button"
                        onclick="closeModal('editModal')"
                        class="bg-gray-400 text-white px-4 py-2 rounded">
                    Cancel
                </button>

                <button type="submit"
                        class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700">
                    Save Changes
                </button>
            </div>

        </form>
    </div>

</div>

@section Scripts {
    <script>
        function openDetailsModal(id, name, email, userDocument, age) {
            document.getElementById('detailsName').innerText = name;
            document.getElementById('detailsEmail').innerText = email;
            document.getElementById('detailsDocument').innerText = userDocument;
            document.getElementById('detailsAge').innerText = age;
    
            showModal('detailsModal');
        }
    
        function openEditModal(id, name, email, userDocument, age) {
            document.getElementById('editId').value = id;
            document.getElementById('editName').value = name;
            document.getElementById('editEmail').value = email;
            document.getElementById('editDocument').value = userDocument;
            document.getElementById('editAge').value = age;
    
            showModal('editModal');
        }
    
        function showModal(id) {
            const modal = document.getElementById(id);
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }
    
        function closeModal(id) {
            const modal = document.getElementById(id);
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }
        
        window.onclick = function(event) {
            ['detailsModal', 'editModal'].forEach(id => {
                const modal = document.getElementById(id);
                if (event.target === modal) {
                    closeModal(id);
                }
            });
        }
</script>
}