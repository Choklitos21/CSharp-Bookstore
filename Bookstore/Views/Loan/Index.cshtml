@using System.Text.Json
@model Bookstore.Models.LoanViewModel

@{
    ViewData["Title"] = "Loans Dashboard";
    
    var LoanedId = Model.Loans != null 
        ? Model.Loans.SelectMany(l => l.Books.Select(b => b.Id)).ToList() 
        : new List<int>();
}

<div class="max-w-6xl mx-auto space-y-8">

    <div class="bg-white shadow rounded-2xl p-6">
        <h2 class="text-2xl font-semibold text-gray-800 mb-4">
            Create New Loan
        </h2>

        <form asp-controller="Loan" asp-action="Store" method="post" class="grid grid-cols-1 md:grid-cols-2 gap-4">

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">User</label>
                <select name="userId" required class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-gray-800 outline-none mb-4">
                    <option value="">Select a user</option>
                    @foreach (var user in Model.Users)
                    {
                        <option value="@user.Id">@user.Name | @user.Document</option>
                    }
                </select>
                
                <label class="block text-sm font-medium text-gray-700 mb-1">Loan Date</label>
                <input name="date" type="date" required
                       class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-gray-800 outline-none"/>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Select Books</label>
    
                <div class="w-full border rounded-lg p-3 h-48 overflow-y-auto bg-gray-50 focus-within:ring-2 focus-within:ring-gray-800">
                    @foreach (var book in Model.Books)
                    {
                        bool isLoaned = LoanedId.Contains(book.Id);
                        <div class="flex items-center mb-2">
                            <input type="checkbox" name="BookIds" value="@book.Id" 
                                   id="book_@book.Id"
                                   @(isLoaned ? "disabled" : "")
                                   class="h-4 w-4 text-gray-900 border-gray-300 rounded focus:ring-gray-800 disabled:opacity-50">
                            <label for="book_@book.Id" class="ml-2 text-sm cursor-pointer @(isLoaned ? "text-gray-400 line-through" : "text-gray-700")">
                                @book.Title | @book.Author @(isLoaned ? "(Already on loan)" : "")
                            </label>
                        </div>
                    }
                </div>
            </div>

            <div class="md:col-span-2 text-right">
                <button type="submit"
                        class="bg-gray-900 text-white px-6 py-2 rounded-lg hover:bg-gray-700 transition">
                    Save Loan
                </button>
            </div>

        </form>
    </div>

    <div class="bg-white shadow rounded-2xl p-6">
        <h2 class="text-2xl font-semibold text-gray-800 mb-4">
            Registered Loans
        </h2>

        <div class="overflow-x-auto">
            <table class="min-w-full border border-gray-200 rounded-lg overflow-hidden">
                <thead class="bg-gray-900 text-white">
                <tr>
                    <th class="px-4 py-2 text-left text-sm">User</th>
                    <th class="px-4 py-2 text-left text-sm">Books</th>
                    <th class="px-4 py-2 text-left text-sm">Date</th>
                    <th class="px-4 py-2 text-left text-sm">Actions</th>
                </tr>
                </thead>

                <tbody class="bg-white divide-y">
                @if (Model.Loans != null && Model.Loans.Any())
                {
                    foreach (var loan in Model.Loans)
                    {
                        var allBookTitles = string.Join(", ", loan.Books.Select(b => b.Title));
                        var allBookIdsJson = JsonSerializer.Serialize(loan.Books.Select(b => b.Id));
                        
                        <tr class="hover:bg-gray-100 transition">
                            <td class="px-4 py-2">@loan.UserLoans.FirstOrDefault()?.User.Name</td>
                            <td class="px-4 py-2">
                                <span class="truncate block max-w-xs" title="@allBookTitles">
                                    @allBookTitles
                                </span>
                            </td>
                            <td class="px-4 py-2">@loan.Date.ToShortDateString()</td>
                            <td class="px-4 py-2 space-x-2">

                                <button
                                    class="bg-green-500 text-white px-3 py-1 rounded hover:bg-green-600 text-sm"
                                    onclick="openDetailsModal(
                                        '@loan.UserLoans.FirstOrDefault()?.User.Name',
                                        '@Html.Raw(allBookTitles.Replace("'", "\\'"))',
                                        '@loan.Date.ToString("yyyy-MM-dd")')">
                                    Details
                                </button>
                                
                                <button
                                    class="bg-blue-500 text-white px-3 py-1 rounded hover:bg-blue-600 text-sm"
                                    onclick="openEditModal(
                                        @loan.Id,
                                        @loan.UserLoans.FirstOrDefault()?.User.Id, 
                                        @allBookIdsJson, 
                                        '@loan.Date.ToString("yyyy-MM-dd")')">
                                    Edit
                                </button>

                                <form asp-controller="Loan" asp-action="DeleteLoan" asp-route-id="@loan.Id" 
                                      method="post" class="inline">
                                    <button type="submit"
                                            class="bg-red-500 text-white px-3 py-1 rounded hover:bg-red-600 text-sm">
                                        Delete
                                    </button>
                                </form>

                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center px-4 py-4 text-gray-500">
                            No loans registered yet.
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div id="detailsModal" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50">
    <div class="bg-white rounded-2xl shadow-lg w-full max-w-md p-6">
        <h2 class="text-xl font-semibold mb-4">Loan Details</h2>
        <div class="space-y-2 text-gray-700">
            <p><strong>User:</strong> <span id="detailsUser"></span></p>
            <p><strong>Books:</strong> <span id="detailsBook"></span></p>
            <p><strong>Date:</strong> <span id="detailsDate"></span></p>
        </div>
        <div class="mt-6 text-right">
            <button onclick="closeModal('detailsModal')" class="bg-gray-800 text-white px-4 py-2 rounded hover:bg-gray-700">Close</button>
        </div>
    </div>
</div>

<div id="editModal" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50">
    <div class="bg-white rounded-2xl shadow-lg w-full max-w-md p-6">
        <h2 class="text-xl font-semibold mb-4">Edit Loan</h2>
        <form method="post" asp-controller="Loan" asp-action="EditLoan">
            <input type="hidden" id="editId" name="loanId" />
            <div class="space-y-4">
                <div>
                    <label class="block text-sm mb-1">User</label>
                    <select id="editUserId" name="UserId" class="w-full px-3 py-2 border rounded-lg">
                        @foreach (var user in Model.Users) { <option value="@user.Id">@user.Name | @user.Document</option> }
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Select Books</label>
                    <div class="w-full border rounded-lg p-3 h-40 overflow-y-auto bg-gray-50">
                        @foreach (var book in Model.Books)
                        {
                            <div class="flex items-center mb-2">
                                <input type="checkbox" name="newBooksIds" value="@book.Id" 
                                       id="edit_book_@book.Id"
                                       data-loaned="@(LoanedId.Contains(book.Id) ? "true" : "false")"
                                       data-original-text="@book.Title | @book.Author"
                                       class="edit-book-checkbox h-4 w-4 text-gray-900 border-gray-300 rounded focus:ring-gray-800 disabled:opacity-50">
                                <label for="edit_book_@book.Id" id="edit_label_@book.Id" class="ml-2 text-sm text-gray-700 cursor-pointer">
                                    @book.Title | @book.Author
                                </label>
                            </div>
                        }
                    </div>
                </div>
                <div>
                    <label class="block text-sm mb-1">Loan Date</label>
                    <input id="editLoanDate" name="date" type="date" class="w-full px-3 py-2 border rounded-lg"/>
                </div>
            </div>
            <div class="mt-6 flex justify-end space-x-2">
                <button type="button" onclick="closeModal('editModal')" class="bg-gray-400 text-white px-4 py-2 rounded">Cancel</button>
                <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700">Save Changes</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function openDetailsModal(user, books, date) {
            document.getElementById('detailsUser').innerText = user;
            document.getElementById('detailsBook').innerText = books;
            document.getElementById('detailsDate').innerText = date;
            showModal('detailsModal');
        }
    
        function openEditModal(id, userId, bookIdsArray, date) {
            document.getElementById('editId').value = id;
            document.getElementById('editUserId').value = userId;
            document.getElementById('editLoanDate').value = date;
            
            // Evaluar cada checkbox usando los data-attributes y la lista actual
            document.querySelectorAll('.edit-book-checkbox').forEach(cb => {
                const bookId = parseInt(cb.value);
                const isGenerallyLoaned = cb.getAttribute('data-loaned') === 'true';
                const belongsToCurrentLoan = bookIdsArray && bookIdsArray.includes(bookId);
                const label = document.getElementById('edit_label_' + bookId);
                const originalText = cb.getAttribute('data-original-text');

                if (belongsToCurrentLoan) {
                    cb.checked = true;
                    cb.disabled = false;
                    label.className = "ml-2 text-sm text-gray-700 cursor-pointer";
                    label.innerText = originalText;
                } else if (isGenerallyLoaned) {
                    cb.checked = false;
                    cb.disabled = true;
                    label.className = "ml-2 text-sm text-gray-400 line-through cursor-pointer";
                    label.innerText = originalText + " (Already on loan)";
                } else {
                    cb.checked = false;
                    cb.disabled = false;
                    label.className = "ml-2 text-sm text-gray-700 cursor-pointer";
                    label.innerText = originalText;
                }
            });

            showModal('editModal');
        }
    
        function showModal(id) {
            const modal = document.getElementById(id);
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }
    
        function closeModal(id) {
            const modal = document.getElementById(id);
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }
        
        window.onclick = function(event) {
            ['detailsModal', 'editModal'].forEach(id => {
                const modal = document.getElementById(id);
                if (event.target === modal) {
                    closeModal(id);
                }
            });
        }
    </script>
}